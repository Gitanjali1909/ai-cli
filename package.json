{
  "name": "ai-cli-judge",
  "displayName": "AI CLI Judge",
  "description": "VS Code extension for local Ollama-powered code explanation, fixing, and review.",
  "version": "0.1.0",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:aiCliJudge.explainCode",
    "onCommand:aiCliJudge.fixCode",
    "onCommand:aiCliJudge.reviewCode",
    "onCommand:aiCliJudge.toggleJudgeMode"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "aiCliJudge.explainCode",
        "title": "AI CLI: Explain Code"
      },
      {
        "command": "aiCliJudge.fixCode",
        "title": "AI CLI: Fix Code"
      },
      {
        "command": "aiCliJudge.reviewCode",
        "title": "AI CLI: Review Code"
      },
      {
        "command": "aiCliJudge.toggleJudgeMode",
        "title": "AI CLI: Toggle Judge Mode"
      }
    ],
    "configuration": {
      "title": "AI CLI Judge",
      "properties": {
        "aiCliJudge.judgeMode": {
          "type": "boolean",
          "default": true,
          "description": "Enable Amitabh Bachchan Senior Dev Judge Mode."
        },
        "aiCliJudge.model": {
          "type": "string",
          "default": "phi",
          "description": "Ollama model name to use."
        },
        "aiCliJudge.timeoutMs": {
          "type": "number",
          "default": 120000,
          "description": "Timeout for Ollama requests in milliseconds."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.5.3"
  }
}
